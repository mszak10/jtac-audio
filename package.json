    "icons": "node scripts/generate-icons.mjs",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.34",
