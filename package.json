{
  "name": "jtac-audio",
  "private": true,
  "version": "0.1.0",
  "description": "Chrome extension that routes a tab's audio to left or right channel only",
  "license": "MIT",
  "author": "Mikołaj Szpakowski <mikolaj@mszp.pl>",
  "homepage": "https://github.com/mszak10/jtac-audio",
